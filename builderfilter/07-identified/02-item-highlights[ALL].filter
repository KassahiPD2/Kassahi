// ------------------------------------------------------------------------------
// Tool-tip Pts AMU / RING / JEWEL - raw weighted score / divisor as N.NN Pt
// ------------------------------------------------------------------------------
// Weights live in PTSRING_* / PTSAMU_* / PTSJEW_* aliases (06-score_pts_formula).
// Color: ORANGE in the 3-5 Pt band (4-5 for LLD/HLD rings and HLD amu), PURPLE above.
// ------------------------------------------------------------------------------

// PVM Melee Ring
ItemDisplay[rin !UNI !SET ID MINDMG+MAXDMG>9 $f(ROUND(PTSRING_MELEE*100/PTS_RING_DIV/100))~3-5]: %CONTINUE%%DOT-0A%%NAME% %ORANGE%$f(ROUND(%PTSRING_MELEE%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%ORANGE%$f(ROUND(%PTSRING_MELEE%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% PVM Melee Ring%CL%%NAME%}
ItemDisplay[rin !UNI !SET ID MINDMG+MAXDMG>9 $f(ROUND(PTSRING_MELEE*100/PTS_RING_DIV/100))>5]: %CONTINUE%%DOT-0A%%NAME% %PURPLE%$f(ROUND(%PTSRING_MELEE%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%PURPLE%$f(ROUND(%PTSRING_MELEE%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% PVM Melee Ring%CL%%NAME%}

// PVM Caster Ring (STAT86/STAT138 weights baked into alias - 2 of either = 1 Pt)
ItemDisplay[rin !UNI !SET ID FCR>0 $f(ROUND(PTSRING_CASTER*100/PTS_RING_DIV/100))~3-5]: %CONTINUE%%DOT-0A%%NAME% %ORANGE%$f(ROUND(%PTSRING_CASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%ORANGE%$f(ROUND(%PTSRING_CASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% PVM Caster Ring%CL%%NAME%}
ItemDisplay[rin !UNI !SET ID FCR>0 $f(ROUND(PTSRING_CASTER*100/PTS_RING_DIV/100))>5]: %CONTINUE%%DOT-0A%%NAME% %PURPLE%$f(ROUND(%PTSRING_CASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%PURPLE%$f(ROUND(%PTSRING_CASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% PVM Caster Ring%CL%%NAME%}

// LLD Melee Ring
ItemDisplay[rin !UNI !SET ID LVLREQ<31 STR>14 $f(ROUND(PTSRING_LLDMELEE*100/PTS_RING_DIV/100))~4-5]: %CONTINUE%%DOT-0A%%NAME% %ORANGE%$f(ROUND(%PTSRING_LLDMELEE%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%ORANGE%$f(ROUND(%PTSRING_LLDMELEE%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% LLD Melee Ring%CL%%NAME%}
ItemDisplay[rin !UNI !SET ID LVLREQ<31 STR>14 $f(ROUND(PTSRING_LLDMELEE*100/PTS_RING_DIV/100))>5]: %CONTINUE%%DOT-0A%%NAME% %PURPLE%$f(ROUND(%PTSRING_LLDMELEE%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%PURPLE%$f(ROUND(%PTSRING_LLDMELEE%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% LLD Melee Ring%CL%%NAME%}

// LLD Caster Ring
ItemDisplay[rin !UNI !SET ID LVLREQ<31 FCR>0 $f(ROUND(PTSRING_LLDCASTER*100/PTS_RING_DIV/100))~4-5]: %CONTINUE%%DOT-0A%%NAME% %ORANGE%$f(ROUND(%PTSRING_LLDCASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%ORANGE%$f(ROUND(%PTSRING_LLDCASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% LLD Caster Ring%CL%%NAME%}
ItemDisplay[rin !UNI !SET ID LVLREQ<31 FCR>0 $f(ROUND(PTSRING_LLDCASTER*100/PTS_RING_DIV/100))>5]: %CONTINUE%%DOT-0A%%NAME% %PURPLE%$f(ROUND(%PTSRING_LLDCASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%PURPLE%$f(ROUND(%PTSRING_LLDCASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% LLD Caster Ring%CL%%NAME%}

// HLD Caster Ring
ItemDisplay[rin !UNI !SET ID STR+DEX>29 FCR>0 $f(ROUND(PTSRING_HLDCASTER*100/PTS_RING_DIV/100))~4-5]: %CONTINUE%%DOT-0A%%NAME% %ORANGE%$f(ROUND(%PTSRING_HLDCASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt{%ORANGE%$f(ROUND(%PTSRING_HLDCASTER%*100/%PTS_RING_DIV%)/100)%GREEN%pt%WHITE% HLD Caster Ring%CL%%NAME%}
