// LLD Caster Amulet (tree skill bump only)
ItemDisplay[amu !UNI !SET ID LVLREQ<31 FCR>0 AMU_TREE_ONLY $f(ROUND(PTSAMU_LLDCASTER*100/PTS_AMU_DIV/100))~3-5]: %CONTINUE%%DOT-0A%%NAME% %ORANGE%$f(ROUND(%PTSAMU_LLDCASTER%*100/%PTS_AMU_DIV%)/100)%GREEN%pt{%ORANGE%$f(ROUND(%PTSAMU_LLDCASTER%*100/%PTS_AMU_DIV%)/100)%GREEN%pt%WHITE% LLD Caster Amulet%CL%%NAME%}
