// LLD Melee Amulet (any class/tree skill bump triggers)
ItemDisplay[amu !UNI !SET ID LVLREQ<31 LIFE>19 AMU_WITH_ANY_CLASS $f(ROUND(PTSAMU_LLDMELEE*100/PTS_AMU_DIV/100))~3-5]: %CONTINUE%%DOT-0A%%NAME% %ORANGE%$f(ROUND(%PTSAMU_LLDMELEE%*100/%PTS_AMU_DIV%)/100)%GREEN%pt{%ORANGE%$f(ROUND(%PTSAMU_LLDMELEE%*100/%PTS_AMU_DIV%)/100)%GREEN%pt%WHITE% LLD Melee Amulet%CL%%NAME%}
