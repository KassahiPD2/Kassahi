// PVM Amulet (requires +2 class or +2 tree; STAT86/STAT80 weights baked into alias)
ItemDisplay[amu !UNI !SET ID AMU_WITH_2CLASS $f(ROUND(PTSAMU_PVM*100/PTS_AMU_DIV/100))~3-5]: %CONTINUE%%DOT-0A%%NAME% %ORANGE%$f(ROUND(%PTSAMU_PVM%*100/%PTS_AMU_DIV%)/100)%GREEN%pt{%ORANGE%$f(ROUND(%PTSAMU_PVM%*100/%PTS_AMU_DIV%)/100)%GREEN%pt%WHITE% PVM Amulet%CL%%NAME%}
